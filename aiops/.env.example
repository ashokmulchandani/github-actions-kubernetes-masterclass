# =============================================================================
# AIOPS - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# Use the SAME Telegram bot from your Call Centre project
# Use the SAME Azure OpenAI from your other projects

# =============================================================================
# Azure OpenAI (for AI analysis)
# =============================================================================
AZURE_OPENAI_ENDPOINT=https://testashok1.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_DEPLOYMENT=testashok1-gpt-4o-mini

# =============================================================================
# Telegram (reuse from Call Centre project)
# =============================================================================
TELEGRAM_BOT_TOKEN=your_existing_bot_token_here
TELEGRAM_CHAT_ID=your_existing_chat_id_here

# =============================================================================
# LangSmith (reuse from Agentic-LanggraphCrash project)
# =============================================================================
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=Ashok-AIOps-DevOps

# =============================================================================
# Groq (optional - alternative to Azure OpenAI)
# =============================================================================
GROQ_API_KEY=your_groq_api_key_here
